          <height>51</height>
         </rect>
        </property>
        <property name="styleSheet">
         <string notr="true">/* الشكل الأساسي للزرار مع تكبير الخط */
QPushButton {
    background-color: #cda47b; 
    color: #ffffff; 
    border-radius: 12px;
    padding: 10px 25px; /* زودنا المسافة الداخلية عشان الزرار يكبر مع الكلمة */
    font-weight: bold;
    font-size: 18px; /* &lt;-- هنا كبرنا الخط، لو لسه صغير خليه 20px */
}

/* تأثير لما تقف عليه بالماوس */
QPushButton:hover {
    background-color: #b88e65; 
}

/* تأثير لما تدوس عليه */
QPushButton:pressed {
    background-color: #9f764e; 
}</string>
        </property>
