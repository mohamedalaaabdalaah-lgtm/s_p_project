         </size>
        </property>
        <property name="font">
         <font>
          <pointsize>-1</pointsize>
          <italic>false</italic>
          <bold>true</bold>
          <underline>false</underline>
          <strikeout>false</strikeout>
         </font>
        </property>
        <property name="styleSheet">
         <string notr="true">   QPushButton {
    /* الخلفية شفافة */
    background-color: transparent;
    /* لون الخط (البيج بتاعك) */
    color: #cda47b; 
    /* البرواز */
    border: 2px solid #cda47b;
    /* الحواف دائرية سِنة */
    border-radius: 10px;
    /* الخط عريض (Bold) */
    font-weight: bold;
    /* حجم الخط */
    font-size: 18px;
    /* الحجم الصغير */
    min-width: 30px;
    max-width: 50px;
    min-height: 10px;
    max-height: 35px;
}

/* ستايل لما المستخدم يلمس الزرار بالماوس */
QPushButton:hover {
    background-color: #cda47b;
    color: #3e2723; /* يقلب بني غامق عشان يبان */
}</string>
