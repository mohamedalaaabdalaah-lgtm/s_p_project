         <widget class="QWidget" name="welcome_page">
          <property name="styleSheet">
           <string notr="true">/* Background of the welcome page */
#welcome_page {
    background-color: #FFF9F2; /* Creamy White */
}

/* Big Welcome Label */
QLabel {
    color: #4B3832; /* Dark Coffee Brown */
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-weight: bold;
}

/* Big Menu Buttons */
QPushButton {
    background-color: #BE9B7B; /* Latte Brown */
    color: white;
    border-radius: 15px; /* Rounded for that modern look */
    padding: 10px;
    border: 2px solid #854442; /* Deep Espresso border */
}

QPushButton:hover {
    background-color: #854442; /* Darken on hover */
}

QPushButton:pressed {
    background-color: #4B3832;
}</string>
          </property>
