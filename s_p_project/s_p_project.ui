           <property name="styleSheet">
            <string notr="true">/* 1. التصميم الأساسي (النسخة الصارمة) */
QDateEdit, QTimeEdit {
    background: #3e2723 !important; 
    color: #ffffff !important;
    border-radius: 10px;
    padding: 5px;
    /* سطر الحدود ده مهم جداً لأنه بيلغي تحكم الويندوز تماماً */
    border: 1px solid #3e2723 !important; 
}

/* 2. إخفاء وإدماج أزرار الأسهم */
QDateEdit::up-button, QDateEdit::down-button,
QTimeEdit::up-button, QTimeEdit::down-button {
    border: none !important;
    background: transparent !important;
    width: 20px;
}

/* 3. تظبيط شكل السهم الخاص بالنتيجة */
QDateEdit::drop-down {
    border: none !important;
    background: transparent !important;
    width: 25px;
}</string>
