    border-radius: 9px;
    /* الخط عريض (Bold) */
    font-weight: bold;
    /* حجم الخط */
    font-size: 18px;
    /* الحجم الصغير */
    min-width: 20px;
    max-width: 70px;
    min-height: 10px;
    max-height: 35px;
}

/* ستايل لما المستخدم يلمس الزرار بالماوس */
