            <widget class="QTableWidget" name="table_flights">
             <property name="styleSheet">
              <string notr="true">/* The entire table background */
QTableWidget {
    background-color: #FFF9F2; /* Clotted cream / Light latte */
    alternate-background-color: #F2E3D5; /* Soft mocha for alternating rows */
    color: #4B3621; /* Deep espresso text */
    gridline-color: #D2B48C; /* Tan/Bisque lines */
    border: 2px solid #6F4E37; /* Coffee bean brown border */
    font-family: &quot;Segoe UI&quot;, Arial;
    font-size: 14px;
    selection-background-color: #A67B5B; /* Medium roast for selected cells */
    selection-color: white;
}

/* The header (top row) */
QHeaderView::section {
    background-color: #6F4E37; /* Coffee brown */
    color: white;
    padding: 5px;
    border: 1px solid #4B3621;
    font-weight: bold;
}

/* Styling the scrollbars to match */
QScrollBar:vertical {
    border: none;
    background: #F2E3D5;
    width: 10px;
}

QScrollBar::handle:vertical {
    background: #8B5A2B; /* Cinnamon handle */
    min-height: 20px;
    border-radius: 5px;
}

/* Bottom right corner where scrollbars meet */
QTableCornerButton::section {
    background-color: #6F4E37;
}</string>
