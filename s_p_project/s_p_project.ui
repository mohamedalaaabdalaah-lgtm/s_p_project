       <string notr="true">/* Style for the buttons */
QPushButton {
    background-color: #c5a059; /* That gold/coffee color */
    color: white;              /* Button text color */
    border-radius: 15px;       /* Round corners */
    padding: 10px;
    font-size: 16px;
    font-weight: bold;
    min-width: 200px;
}

/* Change color when hovering over the button */
QPushButton:hover {
    background-color: #b38f4d; 
}

/* Style for the Label text */
QLabel {
    color: black;              /* Clean black text */
    font-size: 20px;
    font-family: &quot;Segoe UI&quot;;
    font-weight: bold;
    margin-bottom: 20px;
}</string>
