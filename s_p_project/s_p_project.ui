   <string notr="true">QMainWindow {
    background-color: #ffffff;
}

QLabel#lbl_welcome {
    color: #1a1a1a;
    font-family: 'Segoe UI';
    font-size: 24px;
}

QPushButton#btn_enter {
    background-color: #c5a059; /* A nice Gold/Brass color */
    color: white;
    border-radius: 10px;
    padding: 10px;
    font-weight: bold;
}

QPushButton#btn_enter:hover {
    background-color: #b38f4d; /* Darkens slightly when you point at it */
}</string>
