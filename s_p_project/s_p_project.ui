             <property name="styleSheet">
              <string notr="true">QComboBox {
    background-color: #3e2723;
    color: #ffffff;
    border-radius: 10px;
    padding: 5px;
    border: 1px solid #3e2723;
}

/* 2. منطقة السهم اللي على اليمين */
QComboBox::drop-down {
    border: none; /* بنشيل أي حدود قديمة عشان الشكل يبقى ناعم */
    width: 30px;  /* بندي مساحة للسهم */
}

/* 3. القائمة المنسدلة نفسها (الـ Menu اللي بتفتح) */
QComboBox QAbstractItemView {
    background-color: #3e2723; /* نفس لون الخلفية */
    color: #ffffff;
    border: 1px solid #ffffff; /* إطار أبيض خفيف يحدد القائمة */
    selection-background-color: #5d4037; /* لون أفتح شوية لما تقف بالماوس على اختيار */
    selection-color: #ffffff;
}</string>
