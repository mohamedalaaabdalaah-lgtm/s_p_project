             <property name="styleSheet">
              <string notr="true">QLineEdit {
    background-color: #FFF9F2; /* Creamy Latte */
    border: 2px solid #D2B48C; /* Tan/Bisque */
    border-radius: 15px;      /* Rounded &quot;Coffee Pod&quot; shape */
    padding: 5px 15px;
    color: #4B3621;           /* Espresso text */
    font-size: 14px;
    selection-background-color: #A67B5B; /* Selection color */
}

QLineEdit:focus {
    border: 2px solid #6F4E37; /* Darkens to Coffee Bean when typing */
    background-color: #FFFFFF;
}

/* The Search Button */
QPushButton {
    background-color: #6F4E37; /* Deep Roast */
    color: #FFF9F2;
    border-radius: 15px;
    padding: 5px 15px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #8B5A2B; /* Cinnamon hover effect */
}

QPushButton:pressed {
    background-color: #4B3621; /* Strong Espresso pressed effect */
}</string>
